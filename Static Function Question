class student;
  int rn,mrk;
  static int no_of_std_enrolled;
  function new(int x,y);
    rn=x;
    mrk=y;
    no_of_std_enrolled++;
  endfunction
  
  static function void display();
    $display("=============");
    $display("No.of student enrolled:%0d",no_of_std_enrolled);
    //$display("Roll no=%0d",rn);
    //$display("Mark=%0d",mrk);
    $display("=============");
  endfunction
endclass

module test;
  student std[3],s,s1,s2,s3;
  initial begin
    s=new(1,81);
    s.display();
    s1=new(2,91);
    s1.display();
    s2=new(3,93);
    s2.display();
    foreach(std[i])begin
      std[i]=new(i+1,i+90);
      std[i].display();
    end
    student::display();
    $display("No.of student enrolled:%0d",s3.no_of_std_enrolled);
  end
endmodule
